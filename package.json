{
  "name": "infinite-revenue-hub",
  "version": "1.0.0",
  "description": "🚀💰 Unified autonomous revenue generation system - Everything in perfect unison",
  "main": "core/orchestrator.js",
  "scripts": {
    "start": "node core/orchestrator.js",
    "dev": "nodemon core/orchestrator.js",
    "build": "npm run build:frontend && npm run build:contracts",
    "build:frontend": "cd frontend && npm run build",
    "build:contracts": "cd blockchain/contracts && npx hardhat compile",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "deploy": "node automation/unified-deployment.js",
    "deploy:dev": "NODE_ENV=development npm run deploy",
    "deploy:staging": "NODE_ENV=staging npm run deploy",
    "deploy:prod": "NODE_ENV=production npm run deploy",
    "health-check": "node scripts/health-check.js",
    "backup": "node scripts/backup.js",
    "migrate": "node data/migrations/migrate.js",
    "sync": "node data/sync.js",
    "monitor": "node automation/monitor.js",
    "scale": "node automation/auto-scale.js"
  },
  "keywords": [
    "revenue",
    "automation",
    "blockchain",
    "ai",
    "saas",
    "consulting",
    "unified-system"
  ],
  "author": "Infinite-88",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "redis": "^4.6.0",
    "ws": "^8.14.0",
    "ethers": "^6.8.0",
    "web3": "^4.2.0",
    "@tensorflow/tfjs-node": "^4.14.0",
    "stripe": "^14.5.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "winston": "^3.11.0",
    "prometheus-client": "^15.0.0",
    "bull": "^4.12.0",
    "nodemailer": "^6.9.7",
    "socket.io": "^4.7.4",
    "sharp": "^0.32.6",
    "joi": "^17.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "hardhat": "^2.19.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "eslint": "^8.52.0",
    "prettier": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Infinite-88/infinite-revenue-hub.git"
  },
  "bugs": {
    "url": "https://github.com/Infinite-88/infinite-revenue-hub/issues"
  },
  "homepage": "https://infinite-88.github.io/infinite-revenue-hub"
}